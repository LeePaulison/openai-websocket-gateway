HOST=localhost
PORT=8080

OPENAI_API_KEY=

# Application API that exposes /api/graphql.
API_ORIGIN=http://localhost:3000

# Browser origin allowed to connect over HTTP and WebSocket.
CLIENT_ORIGIN=http://localhost:3000

JWT_ISSUER=http://localhost:3000
JWT_AUDIENCE=http://localhost:3000

# May be a full JWKS URL or an origin; origins resolve to /api/auth/jwks.
JWKS_URL=http://localhost:3000

# Optional separate CORS origin. Defaults to CLIENT_ORIGIN.
# CORS_ORIGIN=http://localhost:3000

# Legacy compatibility only; API_ORIGIN and CLIENT_ORIGIN take precedence.
# NEXTJS_ORIGIN=http://localhost:3000
